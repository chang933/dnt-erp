# PostgreSQL (Supabase). 풀러 사용 시 호스트/포트에 맞게 조정
DATABASE_URL=postgresql+psycopg2://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

SECRET_KEY=change-me-to-long-random-string
ENVIRONMENT=development

# 최초 기동 시 어드민 1명 자동 생성 (둘 다 있을 때만, 이미 있으면 스킵)
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=secure-password

# 추가 허용 CORS origin (쉼표 구분). Vercel 배포 URL 등
# CORS_ORIGINS=https://your-app.vercel.app
