# PostgreSQL (Supabase)
# - 직결: db.xxx.supabase.co:5432
# - 풀러: **Transaction(6543)** 권장 (앱/API). Session(5432)는 동시 연결 한도가 매우 작음.
DATABASE_URL=postgresql+psycopg2://postgres.[REF]:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# SQLAlchemy 풀 (Render 등 단일 워커도 기본 5 권장 — 저장 API 대기 시간 감소)
# DATABASE_POOL_SIZE=5
# DATABASE_MAX_OVERFLOW=10
# DATABASE_POOL_RECYCLE=280

SECRET_KEY=change-me-to-long-random-string
ENVIRONMENT=development

# 최초 기동 시 어드민 1명 자동 생성 (둘 다 있을 때만, 이미 있으면 스킵)
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=secure-password

# 추가 허용 CORS origin (쉼표 구분). Vercel 배포 URL 등
# CORS_ORIGINS=https://your-app.vercel.app
